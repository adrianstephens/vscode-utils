{
	"compilerOptions": {
		"composite": true,
		"target": "es2022",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"strict": true,
		"declaration": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"jsx": "react-jsx",
		"types": ["node"],
	},
	"include": [
		"src/*.ts",
		"src/*.tsx"
	],
	"references": [
		{
			"path": "src/webview"
		}
	]
}